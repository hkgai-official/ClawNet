# =============================================================================
# ClawNet Backend - 环境配置
# 复制为对应环境的 .env.<env> 后按需修改，例如:  cp .env.example .env.v1
# clawnet.sh setup <env> 会加载同名的 .env.<env>
# =============================================================================

# ---- 部署标识 (用于区分多套环境) ----
CLAWNET_ENV=v1
# 后端栈容器前缀 (postgres/redis/backend)，约定为 clawnet-<env>
COMPOSE_PROJECT_NAME=clawnet-v1
# Gateway 环境名 (决定容器名 oc-{env}-..、workspace 名 ws-{env}-..、镜像 env)
GATEWAY_ENV=v1

# ---- 端口 (默认值与 clawnet-setup/admin.sh 假定的 http://localhost:9000 一致) ----
BACKEND_PORT=9000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---- 数据库 ----
POSTGRES_DB=clawnet
POSTGRES_USER=clawnet
POSTGRES_PASSWORD=clawnet          # 生产环境请务必修改
DATABASE_URL=postgresql+asyncpg://clawnet:clawnet@localhost:5432/clawnet

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- 密钥 (生产环境必须修改) ----
JWT_SECRET_KEY=clawnet-secret-key-change-in-production
INTERNAL_API_KEY=clawnet-internal-key-change-in-production

# ---- CORS ----
CORS_ORIGINS=["*"]

# ---- OpenClaw Gateway ----
OPENCLAW_CLIENT_ID=openclaw-control-ui
# 网关镜像名格式，须与 clawnet-setup/multi-run.sh 构建的镜像一致
OPENCLAW_IMAGE_PATTERN=openclaw-{env}:local
# Gateway 容器的 UID/GID (建议设为宿主机当前用户: id -u / id -g，保证 workspace 文件属主正确)
FIX_UID=1001
FIX_GID=1001

# ---- 必填: Workspaces 根目录 ----
# 绝对路径，指向包含 ws-0-template 的目录 (开源版模板位于 clawnet-setup/workspaces)
WORKSPACES_ROOT=/absolute/path/to/clawnet-setup/workspaces

# ---- 必填: Server 回连地址 ----
# Gateway 容器通过此地址回连 Server (blob proxy 等回调)。填后端可达的公网/局域网地址。
SERVER_EXTERNAL_URL=http://<your-server-ip>:9000

# ---- 可选 ----
# SERPAPI_API_KEY=your-serpapi-key
# ANTHROPIC_API_KEY=your-api-key
# OPENAI_API_KEY=your-api-key

# ---- Debug ----
DEBUG=true
